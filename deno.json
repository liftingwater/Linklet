{
  "tasks": {
    "start": "deno serve -A --unstable-kv --unstable-net src/main.ts",
    "dev": "deno serve --watch --env -A --unstable-kv --unstable-net src/main.ts",
    "test": "deno test --unstable-kv --unstable-net tests/"
  },
  "imports": {
    "@deno/kv-oauth": "jsr:@deno/kv-oauth@^0.11.0",
    "@std/assert": "jsr:@std/assert@1",
    "@std/collections": "jsr:@std/collections@^1.1.6",
    "@std/encoding": "jsr:@std/encoding@^1.0.7",
    "@std/http": "jsr:@std/http@1",
    "preact": "npm:preact@^10.29.1",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.7"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
